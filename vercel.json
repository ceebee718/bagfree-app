{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/sw.js",
      "headers": { "Cache-Control": "no-cache", "Content-Type": "application/javascript" },
      "dest": "/sw.js"
    },
    {
      "src": "/manifest.json",
      "headers": { "Content-Type": "application/manifest+json" },
      "dest": "/manifest.json"
    },
    {
      "src": "/hero.jpeg",
      "dest": "/hero.jpeg"
    },
    {
      "src": "/icon-192.png",
      "dest": "/icon-192.png"
    },
    {
      "src": "/icon-512.png",
      "dest": "/icon-512.png"
    },
    {
      "src": "/departure-lounge",
      "dest": "/departure-lounge.html"
    },
    {
      "src": "/departure-lounge.html",
      "dest": "/departure-lounge.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
